# ─── Banco de dados ───────────────────────────────────────────────
# Supabase: postgresql://postgres:[SENHA]@db.[REF].supabase.co:5432/postgres
# Local:    postgresql://postgres:senha@localhost:5432/ersus360
DATABASE_URL=postgresql://postgres:senha@localhost:5432/ersus360

# ─── Segurança JWT ────────────────────────────────────────────────
SECRET_KEY=troque-por-uma-chave-segura-de-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ─── Anthropic (IA Gestora) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── FNS / Ministério da Saúde ────────────────────────────────────
FNS_BASE_URL=https://consultafns.saude.gov.br
FNS_MUNICIPIO_IBGE=1300144   # Código IBGE de Apuí/AM
FNS_SYNC_HORA=06:00          # Horário do sync automático diário
FNS_TIMEOUT_SECONDS=30

# ─── App ──────────────────────────────────────────────────────────
APP_NAME=ERSUS 360
MUNICIPIO_NOME=Apuí
MUNICIPIO_UF=AM
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Armazenamento de Arquivos ─────────────────────────────────────
# Diretório local (desenvolvimento):
UPLOAD_DIR=/tmp/ersus360
# MinIO (produção):
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=ersus360
